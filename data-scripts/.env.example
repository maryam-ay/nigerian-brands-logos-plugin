# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains secrets

# Your Figma Personal Access Token
# Get it from: Figma Desktop → Help & Account → Account Settings → Personal access tokens
FIGMA_TOKEN=your_figma_token_here

# The Figma file key for the community logo file (already set)
FIGMA_FILE_KEY=1423382612609415986

# Your GitHub Personal Access Token (needs repo scope)
# Get it from: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_token_here

# Your GitHub username
GITHUB_OWNER=maryam-ay

# The name of your GitHub repository
GITHUB_REPO=nigerian-brands-logos-plugin

# Admin password hash (SHA-256 of your chosen password)
# Leave blank — the plugin lets you set a password on first launch
ADMIN_PASSWORD_HASH=

# GitHub fine-grained token for suggestions (issues:write only, no repo access)
# Create at: GitHub → Settings → Developer settings → Fine-grained tokens
SUGGESTIONS_TOKEN=your_suggestions_token_here
